<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>BETIVO — Social Gaming Platform</title>
    <meta name="description" content="BETIVO — modular social gaming web app with real-time leaderboards, shop, and audio." />
    <link rel="icon" href="/assets/images/favicon.ico" />
    <!-- Core styles -->
    <link rel="stylesheet" href="/styles/base.css" />
    <link rel="stylesheet" href="/styles/layout.css" />
    <link rel="stylesheet" href="/styles/components.css" />
    <link rel="stylesheet" href="/styles/games.css" />
    <link rel="stylesheet" href="/styles/effects.css" />
    <script type="module" src="/src/index.js" defer></script>
  </head>

  <body class="betivo-root" data-theme="light">
    <!-- Accessible skip link -->
    <a class="skip-link" href="#main">Skip to content</a>

    <!-- Header -->
    <header class="site-header" role="banner">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="BETIVO home">
          <img src="/assets/images/logo.svg" alt="BETIVO logo" class="brand-logo" />
          <span class="brand-name">BETIVO</span>
        </a>

        <nav class="main-nav" aria-label="Main navigation">
          <ul class="nav-list">
            <li><a href="#games">Games</a></li>
            <li><a href="#leaderboard">Leaderboard</a></li>
            <li><a href="#shop">Shop</a></li>
            <li><a href="#support">Support</a></li>
          </ul>
        </nav>

        <div class="header-actions">
          <button id="walletBtn" class="btn btn-ghost" aria-haspopup="dialog" aria-controls="walletPanel">Wallet</button>
          <button id="loginBtn" class="btn btn-primary">Sign in</button>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main" class="site-main" role="main">
      <section id="hero" class="hero container">
        <div class="hero-left">
          <h1 class="hero-title">BETIVO</h1>
          <p class="hero-sub">Fast, social micro‑gaming with real‑time leaderboards and a modular game engine.</p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="#games">Play Now</a>
            <a class="btn btn-outline" href="#leaderboard">View Leaderboard</a>
          </div>
        </div>

        <div class="hero-right" aria-hidden="false">
          <div class="player-card" id="nowPlayingCard" aria-live="polite">
            <div class="player-art">
              <img src="/assets/images/cover-placeholder.jpg" alt="" />
            </div>
            <div class="player-meta">
              <div class="player-title">Featured Game</div>
              <div class="player-sub">Blackjack • Roulette • Plinko</div>
            </div>
            <div class="player-controls">
              <button class="icon-btn" id="playPauseBtn" aria-pressed="false" aria-label="Play music">▶</button>
              <button class="icon-btn" id="muteBtn" aria-pressed="false" aria-label="Mute audio">🔊</button>
            </div>
          </div>
        </div>
      </section>

      <section id="games" class="container section">
        <h2 class="section-title">Games</h2>
        <div class="games-grid" role="list">
          <!-- Game card: Blackjack -->
          <article class="game-card" role="listitem" data-game="blackjack" tabindex="0" aria-label="Blackjack">
            <img src="/assets/images/games/blackjack.jpg" alt="Blackjack" />
            <div class="game-card-body">
              <h3>Blackjack</h3>
              <p>Classic 21 with quick rounds and leaderboards.</p>
              <div class="game-card-actions">
                <button class="btn btn-sm btn-primary" data-action="launch" data-game="blackjack">Play</button>
                <button class="btn btn-sm" data-action="info" data-game="blackjack">Info</button>
              </div>
            </div>
          </article>

          <!-- Game card: Roulette -->
          <article class="game-card" role="listitem" data-game="roulette" tabindex="0" aria-label="Roulette">
            <img src="/assets/images/games/roulette.jpg" alt="Roulette" />
            <div class="game-card-body">
              <h3>Roulette</h3>
              <p>Place bets, spin the wheel, and win big.</p>
              <div class="game-card-actions">
                <button class="btn btn-sm btn-primary" data-action="launch" data-game="roulette">Play</button>
                <button class="btn btn-sm" data-action="info" data-game="roulette">Info</button>
              </div>
            </div>
          </article>

          <!-- Game card: Plinko -->
          <article class="game-card" role="listitem" data-game="plinko" tabindex="0" aria-label="Plinko">
            <img src="/assets/images/games/plinko.jpg" alt="Plinko" />
            <div class="game-card-body">
              <h3>Plinko</h3>
              <p>Drop the puck and chase the jackpot.</p>
              <div class="game-card-actions">
                <button class="btn btn-sm btn-primary" data-action="launch" data-game="plinko">Play</button>
                <button class="btn btn-sm" data-action="info" data-game="plinko">Info</button>
              </div>
            </div>
          </article>

          <!-- Add more game cards as needed -->
        </div>
      </section>

      <section id="leaderboard" class="container section">
        <h2 class="section-title">Leaderboard</h2>
        <div class="leaderboard-grid" role="table" aria-label="Leaderboard">
          <div class="leaderboard-header" role="row">
            <div class="col rank">#</div>
            <div class="col player">Player</div>
            <div class="col score">Score</div>
            <div class="col last-play">Last Play</div>
          </div>
          <div id="leaderboardRows" class="leaderboard-rows" role="rowgroup">
            <!-- Rows populated by src/leaderboard.js -->
          </div>
        </div>
      </section>

      <section id="shop" class="container section">
        <h2 class="section-title">Shop</h2>
        <div class="shop-grid" id="shopGrid" role="list">
          <!-- Shop items rendered by src/shop/shop.js -->
        </div>
      </section>

      <section id="support" class="container section">
        <h2 class="section-title">Support</h2>
        <p>If you need help, contact our support team or check the FAQ.</p>
        <div class="support-actions">
          <button class="btn" id="openFaq">FAQ</button>
          <button class="btn" id="contactSupport">Contact Support</button>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="site-footer" role="contentinfo">
      <div class="container footer-inner">
        <div class="footer-left">
          <small>© <span id="currentYear"></span> BETIVO. All rights reserved.</small>
        </div>
        <div class="footer-right">
          <nav aria-label="Footer navigation">
            <ul class="footer-links">
              <li><a href="/terms">Terms</a></li>
              <li><a href="/privacy">Privacy</a></li>
              <li><a href="/status">Status</a></li>
            </ul>
          </nav>
        </div>
      </div>
    </footer>

    <!-- Off-canvas panels and modals -->
    <aside id="walletPanel" class="panel offcanvas" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="walletTitle">
      <header class="panel-header">
        <h3 id="walletTitle">Wallet</h3>
        <button class="panel-close" data-action="close" aria-label="Close wallet">✕</button>
      </header>
      <div class="panel-body">
        <div class="wallet-balance">
          <div class="balance-label">Balance</div>
          <div id="walletBalance" class="balance-amount">0</div>
        </div>
        <div class="wallet-actions">
          <button class="btn btn-primary" id="depositBtn">Deposit</button>
          <button class="btn" id="withdrawBtn">Withdraw</button>
        </div>
      </div>
    </aside>

    <div id="modalRoot" aria-live="polite"></div>

    <!-- Minimal inline script for small runtime behaviors (kept tiny) -->
    <script>
      // Small runtime helpers — keep heavy logic in /src
      document.getElementById('currentYear').textContent = new Date().getFullYear();

      // Basic panel toggles (enhance in src/ui/modal.js)
      const walletBtn = document.getElementById('walletBtn');
      const walletPanel = document.getElementById('walletPanel');
      walletBtn?.addEventListener('click', () => {
        const open = walletPanel.getAttribute('aria-hidden') === 'false';
        walletPanel.setAttribute('aria-hidden', String(!open));
      });

      // Delegate game launch clicks to the app
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-action="launch"]');
        if (btn) {
          const game = btn.dataset.game;
          window.dispatchEvent(new CustomEvent('betivo:launch-game', { detail: { game } }));
        }
      });
    </script>

    <!-- Analytics and optional scripts (defer) -->
    <!-- <script src="/scripts/analytics.js" defer></script> -->
  </body>
</html>
